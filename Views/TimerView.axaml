<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TimeTrace.ViewModels"
             x:Class="TimeTrace.Views.TimerView"
             x:DataType="vm:TimerViewModel"
             Padding="20"
             Background="{StaticResource PageBgBrush}"
             Foreground="{StaticResource TextPrimaryBrush}">
  <StackPanel Spacing="15" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400">
    <TextBlock Text="Timer" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"
               Foreground="{StaticResource TextPrimaryBrush}"/>

    <TextBox Text="{Binding TaskName}" Watermark="Task name" FontSize="16"/>

    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
      <StackPanel>
        <TextBlock Text="Hours" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
        <TextBox Text="{Binding Hours}" Width="80" HorizontalContentAlignment="Center"/>
      </StackPanel>
      <StackPanel>
        <TextBlock Text="Minutes" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
        <TextBox Text="{Binding Minutes}" Width="80" HorizontalContentAlignment="Center"/>
      </StackPanel>
      <StackPanel>
        <TextBlock Text="Seconds" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
        <TextBox Text="{Binding Seconds}" Width="80" HorizontalContentAlignment="Center"/>
      </StackPanel>
    </StackPanel>

    <TextBlock Text="{Binding RemainingTime}" FontSize="36" HorizontalAlignment="Center" FontWeight="Bold"
               Foreground="{StaticResource AccentPurpleBrush}"/>

    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
      <Button Content="Start" Command="{Binding StartTimerCommand}"
              IsEnabled="{Binding !IsRunning}" Classes="primary"/>

      <Button Content="Pause" Command="{Binding StopTimerCommand}"
              IsEnabled="{Binding IsRunning}" Classes="danger"/>
    </StackPanel>

    <Button Content="Reset" Command="{Binding ResetCommand}" HorizontalAlignment="Center"
            Background="{StaticResource SurfaceBgBrush}"
            Foreground="{StaticResource TextPrimaryBrush}"/>

    <TextBlock Text="Timer finished!" IsVisible="{Binding IsFinished}"
               FontSize="18" Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Center"/>
  </StackPanel>
</UserControl>
