<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TimeTrace.App"
             xmlns:local="using:TimeTrace"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <!-- Backgrounds -->
                    <SolidColorBrush x:Key="PageBgBrush" Color="#0F172A" />
                    <SolidColorBrush x:Key="PanelBgBrush" Color="#1E293B" />
                    <SolidColorBrush x:Key="SurfaceBgBrush" Color="#334155" />
                    <SolidColorBrush x:Key="CardBgBrush" Color="#1E293B" />
                    <!-- Text -->
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E2E8F0" />
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8" />
                    <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B" />
                    <SolidColorBrush x:Key="TextAccentBrush" Color="#FBBF24" />
                    <!-- Accents -->
                    <SolidColorBrush x:Key="AccentPurpleBrush" Color="#7C0AED" />
                    <SolidColorBrush x:Key="AccentBlueBrush" Color="#2563EB" />
                    <SolidColorBrush x:Key="AccentRedBrush" Color="#EF4444" />
                    <SolidColorBrush x:Key="AccentGreenBrush" Color="#10B981" />
                    <!-- Buttons -->
                    <SolidColorBrush x:Key="ButtonPrimaryBgBrush" Color="#7C0AED" />
                    <SolidColorBrush x:Key="ButtonDefaultBgBrush" Color="#334155" />
                    <SolidColorBrush x:Key="ButtonDefaultFgBrush" Color="#E2E8F0" />
                    <SolidColorBrush x:Key="ButtonHoverBgBrush" Color="#475569" />
                    <SolidColorBrush x:Key="ButtonDangerBgBrush" Color="#EF4444" />
                    <SolidColorBrush x:Key="ButtonSuccessBgBrush" Color="#10B981" />
                    <!-- Borders -->
                    <SolidColorBrush x:Key="BorderDefaultBrush" Color="#334155" />
                    <SolidColorBrush x:Key="BorderMutedBrush" Color="#475569" />
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="{StaticResource PanelBgBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Padding" Value="15,10" />
            <Setter Property="MinWidth" Value="100" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.nav:hover">
            <Setter Property="Background" Value="{StaticResource SurfaceBgBrush}" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{StaticResource ButtonPrimaryBgBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Padding" Value="20,10" />
        </Style>
        <Style Selector="Button.primary:hover">
            <Setter Property="Background" Value="#6908C9" />
        </Style>
        <Style Selector="Button.danger">
            <Setter Property="Background" Value="{StaticResource ButtonDangerBgBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.danger:hover">
            <Setter Property="Background" Value="#DC2626" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{StaticResource PanelBgBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}" />
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="{StaticResource PanelBgBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefaultBrush}" />
        </Style>
    </Application.Styles>
</Application>
